# Update app.json's expo.extra.apiUrl to point at your backend.
#
# - iOS Simulator: http://localhost:4000/api works fine
# - Android Emulator: use http://10.0.2.2:4000/api instead of localhost
# - Physical device: use your computer's LAN IP, e.g. http://192.168.1.20:4000/api
#   (the device and your backend must be on the same network)
