# ============================================================
# DATABASE
# ============================================================

# Local PostgreSQL example:
# postgresql://postgres:postgres@localhost:5432/piano_with_aaron

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/piano_with_aaron"


# ============================================================
# AUTHENTICATION
# ============================================================

# Replace with a strong random secret.
JWT_SECRET="replace-with-a-long-random-string"

JWT_EXPIRES_IN="7d"

RESET_TOKEN_EXPIRY_MINUTES=30


# ============================================================
# SERVER
# ============================================================

PORT=4000

NODE_ENV="development"

CLIENT_URL="http://localhost:3000"

FRONTEND_URL="http://localhost:3000"


# ============================================================
# PAYSTACK
# ============================================================

# Use your Paystack test keys during local development.
PAYSTACK_SECRET_KEY=""

PAYSTACK_PUBLIC_KEY=""

PAYSTACK_CALLBACK_URL="http://localhost:3000/payment/callback"


# ============================================================
# META / FACEBOOK
# ============================================================

# Piano With Aaron dataset / pixel ID
META_PIXEL_ID="1065172672703214"

# Generate a NEW token because the previous token was exposed.
# Keep this value only in the backend.
META_CONVERSIONS_API_TOKEN="PASTE_NEW_META_TOKEN_HERE"

META_API_VERSION="v24.0"

# Leave blank during normal operation.
# Add a Meta Test Events code temporarily when testing CAPI.
META_TEST_EVENT_CODE=""


# ============================================================
# EMAIL / PASSWORD RESET
# ============================================================

EMAIL_FROM="no-reply@pianowithaaron.com"

SMTP_HOST=""

SMTP_PORT=""

SMTP_USER=""

SMTP_PASS=""
