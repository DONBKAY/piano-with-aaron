# --- Database ---
# Local dev example: postgresql://postgres:postgres@localhost:5432/piano_with_aaron
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/piano_with_aaron"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
RESET_TOKEN_EXPIRY_MINUTES=30

# --- Server ---
PORT=4000
CLIENT_URL="http://localhost:3000"
NODE_ENV="development"

# --- Paystack (added in Phase 3) ---
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# --- Email (for password reset, Phase 1 stub for now) ---
EMAIL_FROM="no-reply@pianowithaaron.com"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
