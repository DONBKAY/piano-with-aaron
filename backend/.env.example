# ============================================================
# DATABASE
# ============================================================

# Local development example:
# postgresql://postgres:postgres@localhost:5432/piano_with_aaron

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/piano_with_aaron"


# ============================================================
# AUTHENTICATION
# ============================================================

# Replace this with a long random secret.
JWT_SECRET="replace-with-a-long-random-string"

JWT_EXPIRES_IN="7d"

RESET_TOKEN_EXPIRY_MINUTES=30


# ============================================================
# SERVER
# ============================================================

PORT=4000

NODE_ENV="development"

CLIENT_URL="http://localhost:3000"

FRONTEND_URL="http://localhost:3000"


# ============================================================
# PAYSTACK
# ============================================================

PAYSTACK_SECRET_KEY=""

PAYSTACK_PUBLIC_KEY=""

# Paystack redirects the user here after payment.
PAYSTACK_CALLBACK_URL="http://localhost:3000/payment/callback"


# ============================================================
# META / FACEBOOK CONVERSIONS API
# ============================================================

META_PIXEL_ID="1065172672703214"

# Keep this private.
# Never put this value in the frontend or in NEXT_PUBLIC variables.
META_CONVERSIONS_API_TOKEN=""

# Use the currently supported Meta Graph API version configured
# for your integration.
META_API_VERSION="v24.0"

# Leave blank during normal use.
# Add your Meta Test Events code only while testing.
META_TEST_EVENT_CODE=""


# ============================================================
# EMAIL / PASSWORD RESET
# ============================================================

EMAIL_FROM="no-reply@pianowithaaron.com"

SMTP_HOST=""

SMTP_PORT=""

SMTP_USER=""

SMTP_PASS=""
